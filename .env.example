# Copy this file to .env.local after cloning.
# Keep .env.local private; do not commit real Firebase or Cloudinary values.

# Firebase web app config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-optional-measurement-id

# Firebase App Check + Functions
VITE_FIREBASE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=optional-local-debug-token
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Public production should use callable Cloud Functions for writes.
# Set to true only for local migration/dev if your Firestore rules allow direct writes.
VITE_ALLOW_DIRECT_FIRESTORE_WRITES=false

# Cloudinary public cloud name is still safe in the browser.
# Signed upload secrets live in Firebase Functions environment variables, not Vite env.
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Legacy local-only unsigned fallback. Leave blank for public production.
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
